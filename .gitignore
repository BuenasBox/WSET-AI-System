# ============================================================================
# WSET-AI-System — .gitignore
# ============================================================================

# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# ----------------------------------------------------------------------------
# Virtual environments
# ----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ----------------------------------------------------------------------------
# Environment / secrets
# ----------------------------------------------------------------------------
.env
.env.*
*.env

# ----------------------------------------------------------------------------
# IDE / Editor
# ----------------------------------------------------------------------------
.vscode/
.idea/

# ----------------------------------------------------------------------------
# OS files
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ----------------------------------------------------------------------------
# Logs
# ----------------------------------------------------------------------------
*.log
logs/
knowledge/wine-with-jimmy/logs/*.log

# ----------------------------------------------------------------------------
# Pytest / coverage
# ----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/

# ----------------------------------------------------------------------------
# Build artifacts
# ----------------------------------------------------------------------------
build/
dist/
*.egg-info/

# ----------------------------------------------------------------------------
# Binary document formats — DO NOT COMMIT
# All documentation must be converted to .md using markitdown before committing.
# Run: markitdown <file> > output.md
# This applies project-wide — no PDFs, Word, Excel, or PowerPoint in the repo.
# ----------------------------------------------------------------------------
*.pdf
*.doc
*.docx
*.xls
*.xlsx
*.ppt
*.pptx
*.odt
*.ods
*.odp

# ----------------------------------------------------------------------------
# Large local-only study materials
# DO NOT PUSH OFFICIAL WSET PDFs OR LARGE BOOKS TO GITHUB
# (covered by the global *.pdf rule above — kept for explicitness)
# ----------------------------------------------------------------------------
knowledge/book/*.pdf
knowledge/book/**/*.pdf

knowledge/official-wset/**/*.pdf
knowledge/official/**/*.pdf

# Official WSET study-guide source PDFs and local extraction artifacts
knowledge/official-wset/study-guide/original/
knowledge/official-wset/study-guide/chapters/
knowledge/official-wset/study-guide/extracted-text/
knowledge/official-wset/study-guide/*.pdf
knowledge/official-wset/study-guide/**/*.pdf

# ----------------------------------------------------------------------------
# Large generated transcript artifacts
# These directories contain generated/pipeline outputs that are machine-local
# and must not be committed to version control.
# The .gitkeep files inside are also excluded; ensure_directories() in
# tools/youtube_transcription/config.py recreates the directory structure.
#
# IMPORTANT: If any of these directories were previously tracked in git,
# run the following before your next commit:
#   git rm --cached -r knowledge/wine-with-jimmy/metadata/
#   git rm --cached -r knowledge/wine-with-jimmy/index/
#   git rm --cached -r knowledge/wine-with-jimmy/reports/
#   git rm --cached -r knowledge/wine-with-jimmy/enrichment-ready/
#   git rm --cached -r knowledge/wine-with-jimmy/embeddings/
# ----------------------------------------------------------------------------

# Raw captions and transcripts (already excluded)
knowledge/wine-with-jimmy/audio/
knowledge/wine-with-jimmy/raw/
knowledge/wine-with-jimmy/clean/
knowledge/wine-with-jimmy/chunk-ready/

# Per-video metadata JSON files (absolute-path risk; machine-local state)
knowledge/wine-with-jimmy/metadata/

# Discovery index outputs (CSV/JSONL of video inventory; machine-local)
knowledge/wine-with-jimmy/index/

# Cleaning and enrichment pipeline outputs
knowledge/wine-with-jimmy/reports/
knowledge/wine-with-jimmy/enrichment-ready/

# Manual curated local SRT imports and generated derivatives
knowledge/wine-with-jimmy/manual-import/srt/
knowledge/wine-with-jimmy/manual-import/processed/
knowledge/wine-with-jimmy/manual-import/reports/
knowledge/wine-with-jimmy/manual-import/rejected/

# Embeddings (never committed — Tier 5 generated, vector-store only)
knowledge/wine-with-jimmy/embeddings/

# ----------------------------------------------------------------------------
# Temporary exports / caches
# ----------------------------------------------------------------------------
tmp/
temp/
.cache/
*.tmp
config.local.*

# ----------------------------------------------------------------------------
# Jupyter
# ----------------------------------------------------------------------------
.ipynb_checkpoints/

# ----------------------------------------------------------------------------
# Optional local databases
# ----------------------------------------------------------------------------
*.sqlite
*.db

# ----------------------------------------------------------------------------
# macOS resource forks
# ----------------------------------------------------------------------------
._*

# ----------------------------------------------------------------------------
# Windows
# ----------------------------------------------------------------------------
desktop.ini

# ============================================================================
# COGNITIVE / EPISTEMIC STATE — NEVER COMMIT
# These are live machine-local cognitive objects. Committing them risks:
# - cognitive leakage (learner state exposed in public repo)
# - operational drift (stale LES imported in fresh sessions)
# - false authority (snapshot of a session treated as canonical truth)
# - accidental Vercel/CI deployment of learner-private data
#
# EXCEPTION: if you intentionally want to version a stable LES seed, do it
# explicitly with `git add -f` and document the decision in CLAUDE.md.
# ============================================================================

# ----------------------------------------------------------------------------
# Learner epistemic state (LES) and session artifacts
# knowledge/nazareth/ is the active cognitive workspace — never auto-tracked.
# ----------------------------------------------------------------------------
knowledge/nazareth/

# ----------------------------------------------------------------------------
# Self-eval dynamic outputs
# sample_questions.json and question_expectations.json ARE intentionally
# versioned (they are config, not runtime output). Everything else is dynamic.
# ----------------------------------------------------------------------------
knowledge/self-eval/reports/
knowledge/self-eval/generated/
knowledge/self-eval/attempts/
knowledge/self-eval/tmp/
knowledge/self-eval/self_eval_summary*.md
knowledge/self-eval/self_eval_results*.json

# ----------------------------------------------------------------------------
# Retrieval sandbox artifacts — derived outputs, not source knowledge
# ----------------------------------------------------------------------------
knowledge/retrieval-sandbox/*.json
knowledge/retrieval-sandbox/*.md

# ----------------------------------------------------------------------------
# JSONL and snapshot stream files — always machine-local pipeline outputs
# ----------------------------------------------------------------------------
*.jsonl
*.snap

# ============================================================================
# TOOLING — Agent / Vercel / Node
# ============================================================================

# ----------------------------------------------------------------------------
# Claude / agent tooling
# ----------------------------------------------------------------------------
.claude/
.skills/

# ----------------------------------------------------------------------------
# Node / npm / Vercel
# ----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next/
.vercel/
.turbo/
out/

# ============================================================================
# REGRESSION HARNESS PROTECTION
# tests/fixtures/tutor_snapshots/ is the regression guard — it MUST stay in
# git. The negation below is a safety net in case a future glob rule would
# accidentally catch it. Do not remove this block.
# ============================================================================
!tests/
!tests/fixtures/
!tests/fixtures/tutor_snapshots/
!tests/fixtures/tutor_snapshots/**
