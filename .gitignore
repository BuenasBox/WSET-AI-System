# ============================================================================
# WSET-AI-System — .gitignore
# ============================================================================

# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# ----------------------------------------------------------------------------
# Virtual environments
# ----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ----------------------------------------------------------------------------
# Environment / secrets
# ----------------------------------------------------------------------------
.env
.env.*
*.env

# ----------------------------------------------------------------------------
# IDE / Editor
# ----------------------------------------------------------------------------
.vscode/
.idea/

# ----------------------------------------------------------------------------
# OS files
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ----------------------------------------------------------------------------
# Logs
# ----------------------------------------------------------------------------
*.log
logs/
knowledge/wine-with-jimmy/logs/*.log

# ----------------------------------------------------------------------------
# Pytest / coverage
# ----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/

# ----------------------------------------------------------------------------
# Build artifacts
# ----------------------------------------------------------------------------
build/
dist/
*.egg-info/

# ----------------------------------------------------------------------------
# Large local-only study materials
# DO NOT PUSH OFFICIAL WSET PDFs OR LARGE BOOKS TO GITHUB
# ----------------------------------------------------------------------------
knowledge/book/*.pdf
knowledge/book/**/*.pdf

knowledge/official-wset/**/*.pdf
knowledge/official/**/*.pdf

# ----------------------------------------------------------------------------
# Large generated transcript artifacts
# Keep locally only unless explicitly needed
# ----------------------------------------------------------------------------
knowledge/wine-with-jimmy/audio/
knowledge/wine-with-jimmy/raw/
knowledge/wine-with-jimmy/clean/
knowledge/wine-with-jimmy/chunk-ready/

# ----------------------------------------------------------------------------
# Temporary exports / caches
# ----------------------------------------------------------------------------
tmp/
temp/
.cache/

# ----------------------------------------------------------------------------
# Jupyter
# ----------------------------------------------------------------------------
.ipynb_checkpoints/

# ----------------------------------------------------------------------------
# Optional local databases
# ----------------------------------------------------------------------------
*.sqlite
*.db

# ----------------------------------------------------------------------------
# macOS resource forks
# ----------------------------------------------------------------------------
._*

# ----------------------------------------------------------------------------
# Windows
# ----------------------------------------------------------------------------
desktop.ini